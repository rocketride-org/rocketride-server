{
	"name": "rocketride",
	"version": "1.0.6",
	"author": "RocketRide, Inc.",
	"license": "MIT",
	"description": "TypeScript client for RocketRide data processing and AI services",
	"type": "commonjs",
	"main": "./dist/cjs/index.js",
	"module": "./dist/esm/index.js",
	"types": "./dist/types/index.d.ts",
	"bin": {
		"rocketride": "./dist/cli/cli/rocketride.js"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/esm/index.js",
			"require": "./dist/cjs/index.js"
		}
	},
	"files": [
		"dist/**/*",
		"README.md"
	],
	"scripts": {},
	"repository": {
		"type": "git",
		"url": "https://github.com/rocketride-org/rocketride-server.git",
		"directory": "packages/client-typescript"
	},
	"homepage": "https://rocketride.ai/",
	"bugs": {
		"url": "https://github.com/rocketride-org/rocketride-server/issues/"
	},
	"keywords": [
		"rocketride",
		"data-processing",
		"ai",
		"websocket",
		"typescript"
	],
	"dependencies": {
		"better-sqlite3": "^12.9.0",
		"commander": "^12.0.0",
		"glob": "^10.5.0",
		"semver": "^7.7.4",
		"tar": "^7.5.8"
	},
	"optionalDependencies": {
		"ws": "^8.18.3"
	},
	"devDependencies": {
		"@jest/globals": "^30.1.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/jest": "^30.0.0",
		"@types/node": "^20.0.0",
		"@types/semver": "^7.7.1",
		"@types/ws": "^8.18.1",
		"jest": "^29.0.0",
		"jest-jasmine2": "^30.2.0",
		"rimraf": "^5.0.5",
		"ts-jest": "^29.4.4",
		"typescript": "^5.0.0",
		"ws": "^8.18.3"
	}
}
