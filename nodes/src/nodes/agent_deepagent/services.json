{
	"title": "Deep Agent",
	"protocol": "agent_deepagent://",
	"classType": ["agent", "tool"],
	"capabilities": ["invoke"],
	"register": "filter",
	"node": "python",
	"path": "nodes.agent_deepagent",
	"prefix": "agent",
	"description": ["Single-agent execution using LangChain DeepAgents.", "Adds strategic planning, persistent state, and long-context management on top of LangChain.", "Can be invoked as a tool (`<nodeId>.run_agent`) for hierarchical agent orchestration."],
	"invoke": {
		"llm": {
			"description": "LLM used by the agent",
			"min": 1
		},
		"tool": {
			"description": "Tools available to the agent (via control-plane invoke)",
			"min": 0
		},
		"memory": {
			"description": "Keyed memory for the agent (via control-plane invoke)",
			"min": 0,
			"max": 1
		}
	},
	"lanes": {
		"questions": ["answers"]
	},
	"input": [
		{
			"lane": "questions",
			"output": [{ "lane": "answers" }]
		}
	],
	"preconfig": {
		"default": "default",
		"profiles": {
			"default": {
				"instructions": []
			}
		}
	},
	"fields": {
		"instructions": {
			"type": "array",
			"title": "Instructions",
			"description": "Additional instructions to guide the agent.",
			"items": {
				"type": "string",
				"format": "textarea"
			}
		},
		"agent_deepagent.default": { "object": "default", "properties": ["instructions"] },
		"agent_deepagent.profile": {
			"title": "Profile",
			"type": "string",
			"default": "default",
			"enum": [["default", "Default"]],
			"conditional": [{ "value": "default", "properties": ["agent_deepagent.default"] }]
		}
	},
	"shape": [
		{
			"section": "Pipe",
			"title": "Deep Agent",
			"properties": ["instructions"]
		}
	]
}
