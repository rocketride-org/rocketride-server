	},
	// Optional:
	//		Local fields definitions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"model": {
			"type": "string",
			"title": "Model",
			"description": "Anthropic model"
		},
		"modelTotalTokens": {
			"type": "number",
			"title": "Tokens",
			"description": "Total Tokens"
		},
		"anthropic.custom": {
			"object": "custom",
			"properties": ["model", "modelTotalTokens", "llm.cloud.apikey", "llm.cloud.modelSource"]
		},
		"anthropic.claude-sonnet-4-6": {
			"object": "claude-sonnet-4-6",
			"properties": ["llm.cloud.apikey", "llm.cloud.modelSource"]
		},
		"anthropic.claude-opus-4-6": {
			"object": "claude-opus-4-6",
			"properties": ["llm.cloud.apikey", "llm.cloud.modelSource"]
		},
		"anthropic.claude-haiku-4-5": {
			"object": "claude-haiku-4-5",
			"properties": ["llm.cloud.apikey", "llm.cloud.modelSource"]
		},
		"anthropic.claude-sonnet-4-5": {
			"object": "claude-sonnet-4-5",
			"properties": ["llm.cloud.apikey", "llm.cloud.modelSource"]
		},
		"anthropic.claude-opus-4-5": {
			"object": "claude-opus-4-5",
			"properties": ["llm.cloud.apikey", "llm.cloud.modelSource"]
		},
		"anthropic.profile": {
			"title": "Model",
			"description": "LLM model",
			"type": "string",
			"default": "claude-sonnet-4-6",
			"enum": ["*>preconfig.profiles.*.title"],
			"conditional": [
				{
					"value": "custom",
					"properties": ["anthropic.custom"]
				},
				{
					"value": "claude-sonnet-4-6",
					"properties": ["anthropic.claude-sonnet-4-6"]
				},
				{
					"value": "claude-opus-4-6",
					"properties": ["anthropic.claude-opus-4-6"]
				},
				{
					"value": "claude-haiku-4-5",
					"properties": ["anthropic.claude-haiku-4-5"]
				},
				{
					"value": "claude-sonnet-4-5",
					"properties": ["anthropic.claude-sonnet-4-5"]
				},
				{
					"value": "claude-opus-4-5",
					"properties": ["anthropic.claude-opus-4-5"]
				},
				{
					"value": "claude-3-5-haiku",
					"properties": ["anthropic.claude-3-5-haiku"]
				},
				{
					"value": "claude-3-7-sonnet",
					"properties": ["anthropic.claude-3-7-sonnet"]
				},
				{
					"value": "claude-3-haiku",
					"properties": ["anthropic.claude-3-haiku"]
				},
				{
					"value": "claude-opus-4",
					"properties": ["anthropic.claude-opus-4"]
				},
				{
					"value": "claude-opus-4-1",
					"properties": ["anthropic.claude-opus-4-1"]
				},
				{
					"value": "claude-opus-4-6-fast",
					"properties": ["anthropic.claude-opus-4-6-fast"]
				},
				{
					"value": "claude-opus-4-7",
					"properties": ["anthropic.claude-opus-4-7"]
				},
				{
					"value": "claude-opus-latest",
					"properties": ["anthropic.claude-opus-latest"]
				},
				{
					"value": "claude-sonnet-4",
					"properties": ["anthropic.claude-sonnet-4"]
				}
			]
		},
		"anthropic.claude-3-5-haiku": {
			"object": "claude-3-5-haiku",
			"properties": ["llm.cloud.apikey", "llm.cloud.modelSource"]
		},
		"anthropic.claude-3-7-sonnet": {
			"object": "claude-3-7-sonnet",
			"properties": ["llm.cloud.apikey", "llm.cloud.modelSource"]
		},
		"anthropic.claude-3-haiku": {
			"object": "claude-3-haiku",
			"properties": ["llm.cloud.apikey", "llm.cloud.modelSource"]
		},
		"anthropic.claude-opus-4": {
			"object": "claude-opus-4",
			"properties": ["llm.cloud.apikey", "llm.cloud.modelSource"]
		},
		"anthropic.claude-opus-4-1": {
			"object": "claude-opus-4-1",
			"properties": ["llm.cloud.apikey", "llm.cloud.modelSource"]
		},
