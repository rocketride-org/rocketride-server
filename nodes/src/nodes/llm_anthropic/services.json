				"title": "Claude Opus 4.5",
				"model": "claude-opus-4-5",
				"modelSource": "manual",
				"modelTotalTokens": 200000, // openrouter
				"modelOutputTokens": 64000, // openrouter
				"apikey": ""
			},
			"claude-3-5-haiku": {
				"title": "Anthropic: Claude 3.5 Haiku",
				"model": "claude-3-5-haiku",
				"modelSource": "openrouter",
				"modelTotalTokens": 200000, // openrouter
				"modelOutputTokens": 8192, // openrouter
				"apikey": ""
			},
			"claude-3-7-sonnet": {
				"title": "Anthropic: Claude 3.7 Sonnet",
				"model": "claude-3-7-sonnet",
				"modelSource": "openrouter",
				"modelTotalTokens": 200000, // openrouter
				"modelOutputTokens": 128000, // openrouter
				"apikey": ""
			},
			"claude-3-haiku": {
				"title": "Anthropic: Claude 3 Haiku",
				"model": "claude-3-haiku",
				"modelSource": "openrouter",
				"modelTotalTokens": 200000, // openrouter
				"modelOutputTokens": 4096, // openrouter
				"apikey": ""
			},
			"claude-opus-4": {
				"title": "Anthropic: Claude Opus 4",
