{
    //
    // Required:
    //		The displayable name of this node
    //
    "title": "Question",
    //
    // Required:
    //		The protocol is the endpoint protocol
    //
    "protocol": "question://",
    //
    // Required:
    //		Class type of the node - what it does
    //
    "classType": [
        "text"
    ],
    //
    // Required:
    //		Capabilities are flags that change the behavior of the underlying
    //		engine
    //
    "capabilities": [
        "gpu"
    ],
    //
    // Optional:
    //		Register is either filter, endpoint or ignored if not specified. If the 
    //		type is specified, a factory is registered of that given type
    //
    "register": "filter",
    //
    // Optional:
    //		The node is the actual pyhsical node to instantiate - if 
    //		not specified, the protocol will be used
    //
    "node": "python",
    //
    // Optional:
    //		The path is the executable/script code - it is node dependent
    // 		and is optional for most node
    //
    "path": "nodes.question",
    //
    // Required:
    //		The prefix map when added/removed when convertting URLs <=> paths
    //
    "prefix": "question",
    //
    // Optional:
    //		Description to of this driver
    //
    "description": [
        "A transformation component that takes input text and encapsulates ",
        "it as a Question object without modification. Designed for structured ",
        "pipelines where raw text is to be handled as a question entity, this ",
        "component enables consistent formatting and downstream processing without ",
		"generating or altering content. If no question is provided, ",
		"the component will skip processing and allow the ",
		"pipeline to continue to the next component without sending a question."
    ],
    //
    // Optional:
    //	  The icon is the icon to display in the UI for this node
    //
    "icon": "question.svg",
    //
    // Optional:
    //	  Documentation link for this driver
    //
    "documentation": "https://bit.ly/47gSR7q",
    //
    //  Optional:
    //      Rendering hints to the UI which indicate which fields of
    //      the configuration should be used to display information
    "tile": [],
    //
    //	Optional:
    //		As a pipe component, define what this pipe component takes
    //		and what it produces
    //
    "lanes": {
        "text": [
            "questions"
        ]
    },
    "input": [
        {
            "lane": "text",
            "output": [
                {
                    "lane": "questions"
                }
            ]
        }
    ],
    //
    //	Optional:
    //		Profile section are configuration optoins used by the driver
    //		itself
    //
    "preconfig": {
        // Define the values that will be merged into any profile configuration
        // specified, unless the profile is 'absolute'
        "default": "default",
        // Defines profiles used with the "profile": key
        "profiles": {
            "default": {
                "question": ""
            }
        }
    },
    //
    // Optional:
    //		Test configuration for automated node testing
    //
    "test": {
        "profiles": [
            "default"
        ],
        "cases": [
            {
                "text": "What is the capital of France?",
                "expect": {
                    "questions": {
                        "equals": "What is the capital of France?"
                    }
                }
            }
        ]
    },
    //
    // Optional:
    //		Local fields defintions - these define fields only for the
    //		current service. You may specify them here, or directly
    //		in the shape
    //
    "fields": {
        "question": {
            "type": "string",
            "title": "Question",
			"description": "Pipeline text query",
			"optional": true
        },
        "question.default": {
            "object": "default",
            "properties": [
                "question"
            ]
        },
        "question.profile": {
            "hidden": true,
            "type": "string",
            "default": "default",
            "enum": [
                [
                    "default",
                    "Default"
                ]
            ],
            "conditional": [
                {
                    "value": "default",
                    "properties": [
                        "question.default"
                    ]
                }
            ]
        }
    },
    //
    // Required:
    //		Defines the fields (shape) of the service. Either source or target
    //		map be specified, or both, but at least one is required
    //
    "shape": [
        {
            "section": "Pipe",
            "title": "Question",
            "properties": [
                "question.profile"
            ]
        }
    ]
}