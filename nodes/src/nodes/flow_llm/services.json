{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Flow If/Else (LLM)",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "flow_llm://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["flow_control"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": [],
	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "filter",
	//
	// Optional:
	//		The node is the actual physical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",
	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	// 		and is optional for most node
	//
	"path": "nodes.flow_llm",
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "flow_llm",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": ["Two-branch conditional router whose decision is made by a wired LLM. ", "The condition is a natural-language yes/no question (e.g. 'Is there a ", "dog in this image?'). The chunk and the question are sent to the LLM ", "via the control-plane invoke channel; the LLM is instructed to reply ", "with one word YES or NO. YES → THEN, anything else → ELSE. Wire a ", "text LLM on the 'llm' channel for text lanes, and a vision-capable ", "LLM on the 'vision' channel for image lanes. Audio and video need ", "preprocessing (STT, frame grabber) upstream — LLM APIs do not accept ", "raw media buffers."],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "util-text.svg",
	"documentation": "https://docs.rocketride.org",
	//
	//  Optional:
	//      Rendering hints to the UI which indicate which fields of
	//		the configuration should be used to display information
	//
	"tile": ["Question: flow_llm.condition"],
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces. `{"*": ["*"]}` is the wildcard contract:
	//		this node accepts any content type and emits the same type
	//		(passthrough). The canvas renders it as a single `any` handle.
	//
	"lanes": {
		"*": ["*"]
	},
	//
	//	Required (flow-control nodes):
	//		Named output branches. The canvas renders one output port per
	//		branch label; the engine dispatches each chunk only to the
	//		branch the condition picked, bypassing the binder broadcast.
	//		Order matches port order on the node: THEN first, ELSE second.
	//
	"branches": ["then", "else"],
	//
	//	Required (flow_llm specific):
	//		Control-plane invoke channels this node consults to decide.
	//		Each channel resolves to its wired target node(s) by `classType`:
	//		`llm` matches `classType: ["llm"]` for text-family lanes,
	//		`vision` matches `classType: ["vision"]` for image lanes.
	//		`min: 0` means wiring is optional — a missing channel that gets
	//		hit at runtime fails closed to ELSE.
	//
	"invoke": {
		"llm": {
			"description": "Text LLM that evaluates the natural-language condition for text-family lanes (text, documents, questions, answers, ...). Connect any llm_* node. Required when routing text lanes; ignored for image lanes.",
			"min": 0
		},
		"vision": {
			"description": "Vision-capable LLM that evaluates the natural-language condition for image lanes. Connect any llm_vision_* node. Required when routing image lanes; ignored for text lanes.",
			"min": 0
		}
	},
	//
	//	Optional:
	//		Profile sections are configuration options used by the driver
	//		itself. Each profile is a named bundle of default field values.
	//
	"preconfig": {
		"default": "default",
		"profiles": {
			"default": {
				"title": "Default",
				"flow_llm.condition": "Does the content match the criterion?",
				"flow_llm.branches": { "then": [], "else": [] }
			}
		}
	},
	//
	// Optional:
	//		Local fields definitions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"flow_llm.condition": {
			"type": "string",
			"title": "Question",
			"description": "Natural-language yes/no question evaluated by the connected LLM. The chunk being routed is provided as context. Write ONLY the question — the node automatically prepends the routing-classifier system prompt and appends the 'Reply with EXACTLY one word: YES or NO' instruction. Do not add 'answer YES/NO' yourself. Examples: 'Is this image a screenshot?', 'Is this text in Spanish?', 'Does the image contain a person?'. Be specific.",
			"default": "Does the content match the criterion?"
		},
		"flow_llm.branches": {
			"type": "object",
			"title": "Branch targets",
			"description": "Maps each branch name to the list of downstream node IDs on that branch. Populated automatically by the canvas when you wire edges from the THEN / ELSE output ports.",
			"properties": {
				"then": { "type": "array", "items": { "type": "string" } },
				"else": { "type": "array", "items": { "type": "string" } }
			},
			"default": { "then": [], "else": [] },
			"optional": true,
			"hidden": true
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		may be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "Flow If/Else (LLM)",
			"properties": ["type", "flow_llm.condition"]
		}
	]
}
