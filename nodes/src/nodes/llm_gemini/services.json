				{ "value": "gemini-3-pro-image-preview", "properties": ["gemini.gemini-3-pro-image-preview"] },
				{ "value": "gemini-2.5-pro", "properties": ["gemini.gemini-2.5-pro"] },
				{ "value": "gemini-2.5-flash", "properties": ["gemini.gemini-2.5-flash"] },
