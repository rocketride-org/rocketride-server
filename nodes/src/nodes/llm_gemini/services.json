		},
		"gemini.gemini-2.5-flash": {
			"object": "gemini-2.5-flash",
			"properties": ["gemini.apikey"]
		},
		"gemini.gemini-2.5-flash-lite": {
			"object": "gemini-2.5-flash-lite",
			"properties": ["gemini.apikey"]
		},
		"gemini.gemini-2.5-flash-image": {
			"object": "gemini-2.5-flash-image",
			"properties": ["gemini.apikey"]
		},
		"gemini.gemini-3-pro-preview": {
			"object": "gemini-3-pro-preview",
			"properties": ["gemini.apikey"]
		},
		"gemini.gemini-3-pro-image": {
			"object": "gemini-3-pro-image",
			"properties": ["gemini.apikey"]
		},
		"gemini.gemini-2_0-flash": {
			"object": "gemini-2_0-flash",
			"properties": ["gemini.apikey"]
		},
		"gemini.gemini-2_0-flash-lite": {
			"object": "gemini-2_0-flash-lite",
			"properties": ["gemini.apikey"]
		},
		"gemini.custom": {
			"object": "custom",
			"properties": ["gemini.model", "gemini.modelTotalTokens", "gemini.outputTokens", "gemini.apikey"]
		},
		"gemini.profile": {
			"title": "Model",
			"description": "Gemini LLM model",
			"type": "string",
			"default": "gemini-3.1-pro-preview",
			"enum": ["*>preconfig.profiles.*.title"],
			"conditional": [
				{ "value": "custom", "properties": ["gemini.custom"] },
				{ "value": "gemini-3.1-pro-preview", "properties": ["gemini.gemini-3.1-pro-preview"] },
				{ "value": "gemini-3.1-flash-image-preview", "properties": ["gemini.gemini-3.1-flash-image-preview"] },
				{ "value": "gemini-3.1-flash-lite-preview", "properties": ["gemini.gemini-3.1-flash-lite-preview"] },
