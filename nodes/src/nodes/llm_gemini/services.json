	//
	// Optional:
	//		Local fields defintions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"gemini.model": {
			"type": "string",
			"title": "Model",
			"description": "Gemini model"
		},
		"gemini.modelTotalTokens": {
			"type": "number",
			"title": "Total Tokens",
			"description": "Maximum number of input + output tokens"
		},
		"gemini.outputTokens": {
			"type": "number",
			"title": "Output Tokens",
			"description": "Maximum number of output tokens"
		},
		"gemini.apikey": {
			"type": "string",
			"title": "API Key",
			"description": "Google AI Developer API key",
			"secure": true,
			"ui": {
				"ui:widget": "ApiKeyWidget"
			}
		},
		"gemini.gemini-3.1-pro-preview": {
			"object": "gemini-3.1-pro-preview",
			"properties": ["gemini.apikey"]
		},
		"gemini.gemini-3.1-flash-image-preview": {
			"object": "gemini-3.1-flash-image-preview",
			"properties": ["gemini.apikey"]
		},
		"gemini.gemini-3.1-flash-lite-preview": {
			"object": "gemini-3.1-flash-lite-preview",
			"properties": ["gemini.apikey"]
		},
		"gemini.gemini-3-flash-preview": {
			"object": "gemini-3-flash-preview",
			"properties": ["gemini.apikey"]
		},
		"gemini.gemini-3-pro-image-preview": {
			"object": "gemini-3-pro-image-preview",
			"properties": ["gemini.apikey"]
		},
		"gemini.gemini-2.5-pro": {
			"object": "gemini-2.5-pro",
