{
  "title": "Exa Search",
  "protocol": "search_exa://",
  "classType": [
    "search"
  ],
  "capabilities": [
    "invoke"
  ],
  "register": "filter",
  "node": "python",
  "path": "nodes.search_exa",
  "prefix": "search",
  "icon": "exa.svg",
  "description": [
    "A direct Exa web search node.",
    "Accepts user questions and returns Exa's raw search JSON as the answer."
  ],
  "tile": [
    "Type: ${parameters.search_exa.type}",
    "Results: ${parameters.search_exa.numResults}"
  ],
  "lanes": {
    "questions": [
      "answers",
      "text"
    ]
  },
  "input": [
    {
      "lane": "questions",
      "output": [
        {
          "lane": "answers"
        },
        {
          "lane": "text"
        }
      ]
    }
  ],
  "preconfig": {
    "default": "default",
    "profiles": {
      "default": {
        "model": "exa-search",
        "modelTotalTokens": 16384,
        "apikey": "",
        "type": "auto",
        "numResults": 5,
        "includeHighlights": true,
        "highlightChars": 600
      }
    }
  },
  "fields": {
    "search_exa.default": {
      "object": "default",
      "properties": [
        "search_exa.type",
        "search_exa.numResults",
        "search_exa.includeHighlights",
        "search_exa.highlightChars"
      ]
    },
    "search_exa.profile": {
      "title": "Profile",
      "type": "string",
      "default": "default",
      "enum": [
        [
          "default",
          "Default"
        ]
      ],
      "conditional": [
        {
          "value": "default",
          "properties": [
            "search_exa.default"
          ]
        }
      ]
    },
    "search_exa.apikey": {
      "type": "string",
      "title": "API Key",
      "description": "Exa API key",
      "default": "",
      "secure": true,
      "ui": {
        "ui:widget": "ApiKeyWidget"
      }
    },
    "search_exa.type": {
      "type": "string",
      "title": "Search Type",
      "default": "auto",
      "enum": [
        [
          "auto",
          "Auto"
        ],
        [
          "keyword",
          "Keyword"
        ],
        [
          "neural",
          "Neural"
        ]
      ]
    },
    "search_exa.numResults": {
      "type": "integer",
      "title": "Results",
      "default": 5,
      "minimum": 1,
      "maximum": 20
    },
    "search_exa.includeHighlights": {
      "type": "boolean",
      "title": "Include Highlights",
      "default": true
    },
    "search_exa.highlightChars": {
      "type": "integer",
      "title": "Highlight Chars",
      "default": 600,
      "minimum": 100,
      "maximum": 4000
    }
  },
  "shape": [
    {
      "section": "Pipe",
      "title": "Exa Search",
      "properties": [
        "search_exa.apikey",
        "search_exa.profile"
      ]
    }
  ],
  "test": {
    "profiles": [
      "default"
    ],
    "outputs": [
      "answers",
      "text"
    ],
    "cases": [
      {
        "name": "Exa returns search results",
        "questions": "Exa API docs",
        "expect": {
          "answers": {
            "contains": "\"requestId\"",
            "notEmpty": true
          },
          "text": {
            "contains": "\"results\"",
            "notEmpty": true
          }
        }
      }
    ]
  }
}
