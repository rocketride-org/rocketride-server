{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Flow If/Else (Python)",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "flow_pyeval://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["flow_control"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": [],
	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "filter",
	//
	// Optional:
	//		The node is the actual physical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",
	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	// 		and is optional for most node
	//
	"path": "nodes.flow_pyeval",
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "flow_pyeval",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": ["Two-branch conditional router. The condition is a sandboxed Python ", "expression evaluated against the active lane payload and the current ", "entry. Truthy → THEN, falsy → ELSE. Streaming lanes (image / audio / ", "video) are buffered until END so the condition sees the complete payload."],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "util-text.svg",
	"documentation": "https://docs.rocketride.org",
	//
	//  Optional:
	//      Rendering hints to the UI which indicate which fields of
	//		the configuration should be used to display information
	//
	"tile": ["Condition: flow_pyeval.condition"],
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces. `{"*": ["*"]}` is the wildcard contract:
	//		this node accepts any content type and emits the same type
	//		(passthrough). The canvas renders it as a single `any` handle.
	//
	"lanes": {
		"*": ["*"]
	},
	//
	//	Required (flow-control nodes):
	//		Named output branches. The canvas renders one output port per
	//		branch label; the engine dispatches each chunk only to the
	//		branch the condition picked, bypassing the binder broadcast.
	//		Order matches port order on the node: THEN first, ELSE second.
	//
	"branches": ["then", "else"],
	//
	//	Optional:
	//		Profile sections are configuration options used by the driver
	//		itself. Each profile is a named bundle of default field values.
	//
	"preconfig": {
		"default": "passthrough",
		"profiles": {
			"passthrough": {
				"title": "Pass-through (always THEN)",
				"flow_pyeval.condition": "True",
				"flow_pyeval.timeout_s": 5,
				"flow_pyeval.branches": { "then": [], "else": [] }
			},
			"non_empty_text": {
				"title": "Non-empty text → THEN, empty → ELSE",
				"flow_pyeval.condition": "len(text) > 0",
				"flow_pyeval.timeout_s": 5,
				"flow_pyeval.branches": { "then": [], "else": [] }
			}
		}
	},
	//
	// Optional:
	//		Local fields definitions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"flow_pyeval.condition": {
			"type": "string",
			"title": "Condition",
			"description": "Python expression. Available bindings: the active lane payload by name (text, table, image, audio, video, questions, answers, documents, classifications), and `obj` for the current entry metadata. Examples: `len(text) > 100`, `image[:4] == b'\\x89PNG'`, `'foo' in text and obj.size >= 1024 * 1024`.",
			"default": "True"
		},
		"flow_pyeval.timeout_s": {
			"type": "integer",
			"title": "Timeout (seconds)",
			"description": "Maximum wall-clock time for a single condition evaluation. Timeout routes to ELSE.",
			"default": 5,
			"minimum": 1,
			"maximum": 60,
			"optional": true
		},
		"flow_pyeval.branches": {
			"type": "object",
			"title": "Branch targets",
			"description": "Maps each branch name to the list of downstream node IDs on that branch. Populated automatically by the canvas when you wire edges from the THEN / ELSE output ports.",
			"properties": {
				"then": { "type": "array", "items": { "type": "string" } },
				"else": { "type": "array", "items": { "type": "string" } }
			},
			"default": { "then": [], "else": [] },
			"optional": true,
			"hidden": true
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		may be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "Flow If/Else (Python)",
			"properties": ["type", "flow_pyeval.condition", "flow_pyeval.timeout_s"]
		}
	]
}
