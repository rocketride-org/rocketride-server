{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "SMB/NAS Share",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "smb://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": [
		"source"
	],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": [
		"filesystem",
		"network",
		"security",
		"nosaas"
	],
	//
	// Optional:
	//		Supported actions - if not specified, no actions are supported
	//		engine
	//
	"actions": [
		"export",
		"delete",
		"download"
	],
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "Shares",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": [
		"A source component that reads data from network-attached storage (NAS), SMB shares, ",
		"or other remote file systems. It enables ingestion of files and documents stored on ",
		"shared network paths for further processing within the pipeline. Configurable with ",
		"share paths, credentials, and file filters, the component supports flexible and secure ",
		"access to unstructured data in various formats across distributed environments."
	],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "smb.svg",
	//
	// Optional:
	//	  Documentation link for this driver
	//
	"documentation": "https://bit.ly/4kXSy4W",
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"_source": [
			"tags"
		]
	},
	"input": [
		{
			"lane": "_source",
			"output": [
				{
					"lane": "tags",
					"description": "Outputs documents to be processed."
				}
			]
		}
	],
	//
	// Optional:
	//		Local fields defintions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"include": {
			"description": "This path defines the paths included for Scan, Index, Classify and OCR. By default, it is empty.\n\nTo scan all shares within the Server for Windows: *\\* and Linux :  */*\n\nTo scan a particular File Share  for Windows: Sharename\\* and Linux: Sharename/*\n\nTo scan a subfolder inside the File Share for Windows: Sharename\\subfolder\\* and Linux: Sharename/subfolder/*"
		},
		"exclude": {
			"description": "This path defines the paths excluded for Scan, Index, Classify and OCR. By default, it is empty.\n\nTo exclude a particular File Share for Windows: Sharename\\* and Linux: Sharename/*\n\nTo exclude a subfolder inside the File Share for Windows: Sharename\\subfolder\\* and Linux: Sharename/subfolder/*"
		},
		"smb.source.parameters": {
			"section": "parameters",
			"title": "Parameters",
			"properties": [
				"smb.server",
				"smb.username",
				"smb.password",
				"excludeSymlinks"
			]
		},
		"smb.target.parameters": {
			"object": "parameters",
			"properties": [
				"smb.server",
				"smb.username",
				"smb.password",
				"smb.storePath"
			]
		},
		"Pipe.include": {
			"description": "Example Path: path\\todata*"
		},
		"Pipe.exclude": {
			"description": "Example Path: path\\todata*"
		},
		"Pipe.smb.source.parameters": {
			"object": "parameters",
			"properties": [
				"smb.server",
				"smb.username",
				"smb.password",
				"excludeSymlinks"
			]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Source",
			"title": "SMB",
			"properties": [
				"type",
				"name",
				"actions",
				"source.mode",
				"smb.source.parameters",
				"include",
				"exclude",
				"estimation"
			]
		},
		{
			"section": "Pipe",
			"title": "SMB",
			"properties": [
				"type",
				"actions",
				"source.mode",
				"Pipe.smb.source.parameters",
				"Pipe.include",
				"Pipe.exclude"
			]
		},
		{
			"section": "Target",
			"title": "SMB",
			"properties": [
				"type",
				"target.mode",
				"smb.target.parameters"
			]
		},
		{
			"section": "Export",
			"title": "SMB",
			"properties": [
				"type",
				"target.mode",
				"smb.target.parameters"
			]
		}
	]
}
