{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Text - Classification",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "classify://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": [
		"text"
	],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": [],
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "Classify",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": [
		"A processing component that categorizes documents based on their ",
		"content. It assigns structured labels or tags to unstructured data, ",
		"enabling downstream filtering, routing, and analysis. Designed for ",
		"flexibility, the component supports custom classification models and ",
		"adapts to diverse document types and domains."
	],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "classification.svg",
	//
	// Optional:
	//	  Documentation link for this driver
	//
	"documentation": "https://bit.ly/3JfrZvr",
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"text": [
			"classifications", "text"
		]
	},
	"input": [
		{
			"lane": "text",
			"output": [
				{
					"lane": "classifications",
					"description": "Outputs the classifications of the document."
				},
            {
					"lane": "text",
					"description": "Document objects with classification metadata added"
				}
			]
		}
	],
	"preconfig": {
		"default": "default",
		"profiles": {
			"default": {}
		}
	},
	//
	// Optional:
	//		Local fields defintions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"classifications": {
			"title": "Classifications",
			"type": ["array", "object"],
			"optional": true,
			"items": {
				"type": "object"
			},
			"ui:widget": "classifications"
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "Classification",
			"properties": [
				"classifications"
			]
		}
	]
}
