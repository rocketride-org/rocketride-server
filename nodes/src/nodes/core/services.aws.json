{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "AWS S3",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "aws://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": [
		"source"
	],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": [
		"network"
	],
	//
	// Optional:
	//		Supported actions - if not specified, no actions are supported
	//		engine
	//
	"actions": [
		"export",
		"delete",
		"download"
	],
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "Amazon Web Services",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": [
		"A source component that reads data from Amazon S3 buckets. It enables ",
		"ingestion of files and documents stored in S3 for further processing within ",
		"the pipeline. Configurable with AWS credentials and bucket settings, the ",
		"component supports secure and scalable access to cloud-hosted data across ",
		"various formats."
	],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "amazon-s3.svg",
	//
	// Optional:
	//	  Documentation link for this driver
	//
	"documentation": "https://bit.ly/48SC3ov",
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"_source": [
			"tags"
		]
	},
	"input": [
		{
			"lane": "_source",
			"output": [
				{
					"lane": "tags",
					"description": "Outputs documents to be processed."
				}
			]
		}
	],
	//
	// Optional:
	//		Local fields defintions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"include": {
			"description": "This path defines the paths included for Scan, File Signature, Index, Classify, and OCR.\nExample Path for AWS S3: BucketName/FolderName/* or BucketName/*"
		},
		"include.path": {
			"description": "This path defines the paths included for Scan, File Signature, Index, Classify, and OCR.\nExample Path for AWS S3: BucketName/FolderName/* or BucketName/*"
		},
		"exclude": {
			"description": "This path defines the paths excluded for Scan, File Signature, Index, Classify, and OCR.\nExample Path for AWS S3: BucketName/FolderName/*"
		},
		"exclude.path": {
			"description": "This path defines the paths excluded for Scan, File Signature, Index, Classify, and OCR.\nExample Path for AWS S3: BucketName/FolderName/*"
		},
		"aws.source.parameters": {
			"section": "parameters",
			"title": "Parameters",
			"properties": [
				"aws.accessKey",
				"aws.secretKey",
				"aws.region"
			]
		},
		"aws.target.parameters": {
			"object": "parameters",
			"properties": [
				"storePath",
				"aws.accessKey",
				"aws.secretKey",
				"aws.region"
			]
		},
		"Pipe.include": {
			"description": "Example path: [bucket_name]/[folder_name]/* or [bucket_name]/*"
		},
		"Pipe.exclude": {
			"description": "Example path: [bucket_name]/[folder_name]/* or [bucket_name]/*"
		},
		"Pipe.aws.source.parameters": {
			"object": "parameters",
			"properties": [
				"aws.accessKey",
				"aws.secretKey",
				"aws.region"
			]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Source",
			"title": "AWS S3",
			"properties": [
				"type",
				"name",
				"actions",
				"source.mode",
				"aws.source.parameters",
				"include",
				"exclude",
				"estimation"
			]
		},
		{
			"section": "Pipe",
			"title": "AWS S3",
			"properties": [
				"type",
				"actions",
				"source.mode",
				"Pipe.aws.source.parameters",
				"Pipe.include",
				"Pipe.exclude"
			]
		},
		{
			"section": "Target",
			"title": "AWS S3",
			"properties": [
				"type",
				"target.mode",
				"aws.target.parameters"
			]
		},
		{
			"section": "Export",
			"title": "AWS S3",
			"properties": [
				"type",
				"target.mode",
				"aws.target.parameters"
			]
		}
	]
}
