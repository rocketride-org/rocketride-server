		"ms.tenant": {
			"type": "string",
			"description": "It is a unique identifier different to your organization name or domain. Tenant Id can be found in Azure Active directory property page",
			"title": "Tenant Id",
			"readonly": true
		},
		"ms.clientId": {
			"type": "string",
			"title": "Client Id",
			"description": "The Client Id created for your application (configuration in Azure).",
			"secure": true,
			"ui:options": {
				"hideFor": "personal"
			}
		},
		"ms.clientSecret": {
			"type": "string",
			"title": "Client Secret",
			"description": "The Client Secret for your application (configuration in Azure).",
			"secure": true,
			"ui:options": {
				"hideFor": "personal"
			}
		},
		"ms.refreshToken": {
			"type": "string",
			"title": "Refresh Token",
			"description": "The refresh token for your application.",
			"ui:widget": "password"
		},
		"DTC.ms.oAuthButton": {
			"title": "Login with Microsoft",
			"type": "string",
			"ui:widget": "MicrosoftButtonWidget",
			"optional": true
		},
		"DTC.ms.accessToken": {
			"description": "It is a short term token that allows you to access the Microsoft Graph API.",
			"title": "Access Token",
			"type": "string",
			"ui:widget": "password"
		},
		"DTC.ms.refreshToken": {
			"description": "It is a long term token that allows you to get new access tokens to access the Microsoft Graph API.",
			"title": "Refresh Token",
			"type": "string",
			"ui:widget": "password",
			"ui:disabled": true
		},
		"ms.accountName": {
			"type": "string",
			"title": "Account name",
			"description": "This defines the unique namespace in Azure for your data. This is available inside the Azure Portal.",
			"minLength": 3,
			"maxLength": 63,
			"optional": true,
			"secure": true
		},
		"ms.accountPassword": {
			"type": "string",
			"title": "Account password",
			"optional": true,
			"ui:widget": "password"
		},
		"ms.accountKey": {
			"type": "string",
			"title": "Key",
			"description": "This defines the Azure account key needed to access the blob storage. This is available inside the Azure Portal.",
			"minLength": 3,
			"maxLength": 256,
			"optional": true,
			"secure": true,
			"ui:widget": "password"
		},
		"ms.container": {
			"type": "string",
			"title": "Container name",
			"description": "This organizes a set of blobs, similar to directory in a file system. This is available inside the Azure Portal.",
			"minLength": 3,
			"maxLength": 63
		},
		"ms.endpointSuffix": {
			"type": "string",
			"title": "Endpoint suffix",
			"default": "blob.core.windows.net",
			"minLength": 3,
			"maxLength": 63,
			"highlightChangedValue": true
		},
		"ms.auth": {
			"type": "string",
			"title": "Authentication type",
			"default": "password",
			"enum": [
				[
					"password",
					"Username/Password"
				],
				[
					"secure",
					"Secure Web-Web Access"
				]
			],
			"conditional": [
				{
					"value": "secure",
					"properties": [
						"ms.tenant",
						"ms.region",
						"ms.clientId",
						"ms.clientSecret"
					]
				},
				{
					"value": "password",
					"properties": [
						"ms.tenant",
						"ms.region",
						"ms.clientId",
						"ms.accountName",
						"ms.accountPassword"
					]
				}
			]
		},
		"fixed.ms.secure.auth": {
			"hidden": true,
			"type": "string",
			"default": "secure"
		}
	}
