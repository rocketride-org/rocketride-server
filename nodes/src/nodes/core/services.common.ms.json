			"type": "string",
			"title": "Authentication Type",
			"default": "enterprise",
			"readonly": true,
			"enum": [
				[
					"enterprise",
					"Enterprise"
				],
				[
					"personal",
					"Personal"
				]
			],
			"conditional": [
				{
					"value": "enterprise",
					"properties": [
						"ms.tenant",
						"ms.region",
						"ms.clientId",
						"ms.clientSecret"
					]
				},
				{
					"value": "personal",
					"properties": [
						"ms.clientId",
						"ms.clientSecret",
						"DTC.ms.oAuthButton",
						"DTC.ms.refreshToken"
					]
				}
			]
		},
		"DTC.ms.authType": {
