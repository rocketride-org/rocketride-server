{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Microsoft Outlook - Personal",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "outlook-personal://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": [
		"source"
	],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": [
		"network",
		"sync"
	],
	//
	// Optional:
	//		Supported actions - if not specified, no actions are supported
	//		engine
	//
	"actions": [
		"export",
		"download"
	],
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "Microsoft/Outlook",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": [
		"A source component that connects to Office365 Outlook to ingest emails for ",
		"downstream processing. It supports reading from configured mailboxes or folders ",
		"using secure authentication. The component enables extraction of message content, ",
		"metadata, and attachments, making Outlook emails available for classification, ",
		"analysis, and archival workflows."
	],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "outlook.svg",
	//
	// Optional:
	//	  Documentation link for this driver
	//
	"documentation": "https://bit.ly/4kRVlg0",
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"_source": [
			"tags"
		]
	},
	"input": [
		{
			"lane": "_source",
			"output": [
				{
					"lane": "tags",
					"description": "Outputs documents to be processed."
				}
			]
		}
	],
	//
	// Optional:
	//		Local fields defintions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"authType": {
			"type": "string",
			"title": "Authentication Type",
			"default": "personal",
			"hidden": true
		},
		"include": {
			"description": "This path defines the paths included for Scan, Index, Classify and OCR. By default, its empty.\n\nUse * to scan all the user accounts. For individual user folders, use user ID\\FolderName. Example: aparavitest@microsoft.com\\Folder1\\*"
		},
		"include.path": {
			"description": "This path defines the paths included for Scan, Index, Classify and OCR. By default, its empty.\n\nUse * to scan all the user accounts. For individual user folders, use user ID\\FolderName. Example: aparavitest@microsoft.com\\Folder1\\*"
		},
		"exclude": {
			"description": "This path defines the paths excluded for Scan, Index, Classify and OCR. By default, its empty.\n\n Use * to exclude all the user accounts. For individual user account, use user ID\\FolderName. Example: aparavitest@microsoft.com\\Folder1\\*"
		},
		"exclude.path": {
			"description": "This path defines the paths excluded for Scan, Index, Classify and OCR. By default, its empty.\n\n Use * to exclude all the user accounts. For individual user account, use user ID\\FolderName. Example: aparavitest@microsoft.com\\Folder1\\*"
		},
		"outlook.source.parameters": {
			"section": "parameters",
			"title": "Parameters",
			"properties": [
				"fixed.ms.secure.auth",
				"ms.authType"
			]
		},
		"Pipe.include": {
			"description": "Example path: [folder_name]/*",
			"default": [
				{ "path": "*" }
			]
		},
		"Pipe.exclude": {
			"description": "Example path: [folder_name]/*"
		},
		"Pipe.outlook.source.parameters": {
			"section": "parameters",
			"properties": [
				"authType",
				"fixed.ms.secure.auth",
                "DTC.ms.oAuthButton",
                "DTC.ms.refreshToken"
			]
		},
        "DTC.ms.refreshToken": {
            "hidden": true
        }
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Source",
			"title": "Outlook",
			"properties": [
				"type",
				"name",
				"actions",
				"sync",
				"source.mode",
				"outlook.source.parameters",
				"include",
				"exclude",
				"estimation"
			]
		},
		{
			"section": "Pipe",
			"title": "Outlook",
			"properties": [
				"type",
				"actions",
				"source.mode",
				"Pipe.outlook.source.parameters",
				"Pipe.include",
				"Pipe.exclude"
			]
		}
	]
}
