{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Object Storage",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "objstore://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": [
		"source"
	],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": [
		"network"
	],
	//
	// Optional:
	//		Supported actions - if not specified, no actions are supported
	//		engine
	//
	"actions": [
		"export",
		"delete",
		"download"
	],
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "Object Storage",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": [
		"A source component that reads data from generic object store buckets. It enables ",
		"ingestion of files and documents stored in a cloud bucket for further processing within ",
		"the pipeline. Configurable with credentials and bucket settings, the ",
		"component supports secure and scalable access to cloud-hosted data across ",
		"various formats."
	],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "objstore.svg",
	//
	// Optional:
	//	  Documentation link for this driver
	//
	"documentation": "https://bit.ly/3LEzPze",
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"_source": [
			"tags"
		]
	},
	"input": [
		{
			"lane": "_source",
			"output": [
				{
					"lane": "tags",
					"description": "Outputs documents to be processed."
				}
			]
		}
	],
	//
	// Optional:
	//		Local fields defintions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"include": {
			"description": "This path defines the paths included for Scan, File Signature, Index, Classify, and OCR.\nExample Path for AWS S3: BucketName/FolderName/* or BucketName/*"
		},
		"include.path": {
			"description": "This path defines the paths included for Scan, File Signature, Index, Classify, and OCR.\nExample Path for AWS S3: BucketName/FolderName/* or BucketName/*"
		},
		"exclude": {
			"description": "This path defines the paths excluded for Scan, File Signature, Index, Classify, and OCR.\nExample Path for AWS S3: BucketName/FolderName/*"
		},
		"exclude.path": {
			"description": "This path defines the paths excluded for Scan, File Signature, Index, Classify, and OCR.\nExample Path for AWS S3: BucketName/FolderName/*"
		},
		"objstore.source.parameters": {
			"section": "parameters",
			"title": "Parameters",
			"properties": [
				"url",
				"aws.accessKey",
				"aws.secretKey"
			]
		},
		"objstore.target.parameters": {
			"object": "parameters",
			"title": "Parameters",
			"properties": [
				"storePath",
				"url",
				"aws.accessKey",
				"aws.secretKey"
			]
		},
		"Pipe.include": {
			"description": "Example path: [bucket_name]/[folder]/*"
		},
		"Pipe.exclude": {
			"description": "Example path: [bucket_name]/[folder]/*"
		},
		"Pipe.objstore.source.parameters": {
			"object": "parameters",
			"properties": [
				"url",
				"aws.accessKey",
				"aws.secretKey"
			]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Source",
			"title": "S3 Compatible",
			"properties": [
				"type",
				"name",
				"actions",
				"source.mode",
				"objstore.source.parameters",
				"include",
				"exclude",
				"estimation"
			]
		},
		{
			"section": "Pipe",
			"title": "S3 Compatible",
			"properties": [
				"type",
				"actions",
				"source.mode",
				"Pipe.objstore.source.parameters",
				"Pipe.include",
				"Pipe.exclude"
			]
		},
		{
			"section": "Target",
			"title": "S3 Compatible",
			"properties": [
				"type",
				"target.mode",
				"objstore.target.parameters"
			]
		},
		{
			"section": "Export",
			"title": "S3 Compatible",
			"properties": [
				"type",
				"target.mode",
				"objstore.target.parameters"
			]
		}
	]
}