//
// Common field defintions for Atlassian - these will be merged into the 
// service defintion as required by the service
//
{
	"fields": {
		"atl.url": {
			"type": "string",
			"title": "Atlassian URL",
			"description": "The Atlassian URL."
		},
		"atl.clientId": {
			"type": "string",
			"title": "User email",
			"description": "The user email."
		},
		"atl.clientSecret": {
			"type": "string",
			"title": "Token",
			"description": "The token. Token needs to be obtained at https://id.atlassian.com/manage-profile/security/api-tokens",
			"optional": true,
			"secure": true,
			"ui": {
				"ui:widget": "password"
			}
		}
	}
}
