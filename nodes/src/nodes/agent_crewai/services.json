{
	"title": "CrewAI",
	"protocol": "agent_crewai://",
	"classType": ["agent", "tool"],
	"capabilities": ["invoke"],
	"register": "filter",
	"node": "python",
	"path": "nodes.agent_crewai",
	"prefix": "agent",
	"description": ["Single-agent execution using CrewAI.", "Can be invoked as a tool (`<nodeId>.run_agent`) for hierarchical agent orchestration."],
	"icon": "crewai.svg",
	"invoke": {
		"llm": {
			"description": "LLM used by the agent",
			"min": 1
		},
		"tool": {
			"description": "Tools available to the agent (via control-plane invoke)",
			"min": 0
		},
		"memory": {
			"description": "Keyed memory for the agent (via control-plane invoke)",
			"min": 0,
			"max": 1
		}
	},
	"lanes": {
		"questions": ["answers"]
	},
	"input": [
		{
			"lane": "questions",
			"output": [{ "lane": "answers" }]
		}
	],
	"preconfig": {
		"default": "default",
		"profiles": {
			"default": {
				"agent_description": "",
				"instructions": []
			}
		}
	},
	"fields": {
		"agent_description": {
			"type": "string",
			"title": "Agent description",
			"default": "",
			"optional": true,
			"description": "What does this agent do? Describe its purpose and capabilities — this helps parent agents select and invoke it correctly.",
			"ui": {
				"ui:widget": "textarea"
			}
		},
		"instructions": {
			"type": "array",
			"title": "Instructions",
			"description": "Additional instructions to guide the agent.",
			"items": {
				"type": "string",
				"format": "textarea"
			}
		},
		"agent_crewai.default": { "object": "default", "properties": ["agent_description", "instructions"] },
		"agent_crewai.profile": {
			"title": "Profile",
			"type": "string",
			"default": "default",
			"enum": [["default", "Default"]],
			"conditional": [{ "value": "default", "properties": ["agent_crewai.default"] }]
		}
	},
	"shape": [
		{
			"section": "Pipe",
			"title": "CrewAI",
			"properties": ["agent_description", "instructions"]
		}
	]
}
