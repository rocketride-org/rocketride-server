{
	"title": "Text To Speech",
	"protocol": "audio_tts://",
	"classType": ["audio"],
	"capabilities": [],
	"register": "filter",
	"node": "python",
	"path": "nodes.audio_tts",
	"prefix": "audio_tts",
	"description": ["Converts incoming text into speech audio using local or cloud TTS engines.", "Output is driven by wiring: audio lane streams PCM chunks; text lane emits JSON with mime type and base64 (no server file path — suitable when the engine runs remotely).", "Encoding (WAV vs MP3) is chosen automatically from connected output lanes (not a form field).", "With --modelserver: Coqui/Kokoro/Bark (HF transformers), Piper (ONNX in-process), OpenAI TTS, and ElevenLabs are served or proxied where loaders exist; without it, each engine runs or calls APIs from the engine host.", "Every profile uses curated dropdowns — see ``requirements.txt`` + ``depends()`` on load: ``piper-tts``, ``transformers``, ``lameenc`` (MP3 in-process), ``imageio-ffmpeg`` (ffmpeg fallback), ``requests``, etc."],
	"icon": "audio-player.svg",
	"lanes": {
		"text": ["audio", "text"]
	},
	"input": [
		{
			"lane": "text",
			"description": "Text input for speech synthesis",
			"output": [
				{
					"lane": "audio"
				},
				{
					"lane": "text"
				}
			]
		}
	],
	"preconfig": {
		"default": "piper",
		"profiles": {
			"piper": {
				"engine": "piper",
				"piper_voice": "en_US-lessac-medium"
			},
			"coqui-default": {
				"engine": "coqui",
				"coqui_model": "coqui/XTTS-v2"
			},
			"kokoro-default": {
				"engine": "kokoro",
				"kokoro_model": "hexgrad/Kokoro-82M"
			},
			"bark-default": {
				"engine": "bark",
				"bark_model": "suno/bark-small"
			},
			"openai-tts": {
				"engine": "openai",
				"openai_model": "gpt-4o-mini-tts",
				"openai_voice": "alloy",
				"api_key": ""
			},
			"elevenlabs-default": {
				"engine": "elevenlabs",
				"elevenlabs_model": "eleven_multilingual_v2",
				"elevenlabs_voice": "EXAVITQu4vr4xnSDxMaL",
				"api_key": ""
			}
		}
	},
	"fields": {
		"audio_tts.coqui_model": {
			"type": "string",
			"title": "Model",
			"description": "Hugging Face model for Coqui (text-to-audio).",
			"default": "coqui/XTTS-v2",
			"enum": [["coqui/XTTS-v2", "Coqui XTTS v2"]]
		},
		"audio_tts.kokoro_model": {
			"type": "string",
			"title": "Model",
			"description": "Hugging Face model for Kokoro.",
			"default": "hexgrad/Kokoro-82M",
			"enum": [["hexgrad/Kokoro-82M", "Kokoro 82M"]]
		},
		"audio_tts.bark_model": {
			"type": "string",
			"title": "Model",
			"description": "Hugging Face Bark checkpoint.",
			"default": "suno/bark-small",
			"enum": [
				["suno/bark-small", "Bark small (faster)"],
				["suno/bark-large", "Bark large"],
				["suno/bark", "Bark (full)"]
			]
		},
		"audio_tts.openai_model": {
			"type": "string",
			"title": "Model",
			"description": "OpenAI TTS model id.",
			"default": "gpt-4o-mini-tts",
			"enum": [
				["gpt-4o-mini-tts", "GPT-4o mini TTS"],
				["gpt-4o-tts", "GPT-4o TTS"],
				["tts-1", "TTS-1"],
				["tts-1-hd", "TTS-1 HD"]
			]
		},
		"audio_tts.openai_voice": {
			"type": "string",
			"title": "Voice",
			"description": "OpenAI TTS voice (GPT-4o TTS models support additional voices).",
			"default": "alloy",
			"enum": [
				["alloy", "Alloy"],
				["ash", "Ash"],
				["ballad", "Ballad"],
				["coral", "Coral"],
				["echo", "Echo"],
				["fable", "Fable"],
				["onyx", "Onyx"],
				["nova", "Nova"],
				["sage", "Sage"],
				["shimmer", "Shimmer"],
				["verse", "Verse"],
				["marin", "Marin"],
				["cedar", "Cedar"]
			]
		},
		"audio_tts.elevenlabs_model": {
			"type": "string",
			"title": "Model",
			"description": "ElevenLabs model_id.",
			"default": "eleven_multilingual_v2",
			"enum": [
				["eleven_multilingual_v2", "Multilingual v2"],
				["eleven_turbo_v2_5", "Turbo v2.5"],
				["eleven_flash_v2_5", "Flash v2.5"],
				["eleven_v3", "Eleven v3"],
				["eleven_monolingual_v1", "Monolingual v1"]
			]
		},
		"audio_tts.elevenlabs_voice": {
			"type": "string",
			"title": "Voice",
			"description": "Premade ElevenLabs voice (voice_id).",
			"default": "EXAVITQu4vr4xnSDxMaL",
			"enum": [
				["21m00Tcm4TlvDq8ikWAM", "Rachel"],
				["AZnzlk1XvdvUeBnXmlld", "Domi"],
				["EXAVITQu4vr4xnSDxMaL", "Bella"],
				["ErXwobaYiN019PkySvjV", "Antoni"],
				["MF3mGyEYCl7XYWbV9V6O", "Elli"],
				["TxGEqnHWrfWFTfGW9XjX", "Josh"],
				["VR6AewLTigWG4xSOukaG", "Arnold"],
				["pNInz6obpgDQGcFmaJgB", "Adam"],
				["yoZ06aMxZJJ28mfd3POQ", "Sam"]
			]
		},
		"audio_tts.api_key": {
			"type": "string",
			"title": "API key",
			"secure": true,
			"ui": {
				"ui:widget": "ApiKeyWidget"
			}
		},
		"audio_tts.piper_voice": {
			"type": "string",
			"title": "Voice model",
			"description": "Piper preset from rhasspy/piper-voices (downloaded via Hugging Face Hub on first use).",
			"default": "en_US-lessac-medium",
			"enum": [
				["en_US-lessac-medium", "English (US) — Lessac, medium"],
				["en_US-amy-medium", "English (US) — Amy, medium"],
				["de_DE-thorsten-medium", "German — Thorsten, medium"],
				["es_ES-davefx-medium", "Spanish (Spain) — Davefx, medium"],
				["fr_FR-siwis-medium", "French — Siwis, medium"],
				["it_IT-paola-medium", "Italian — Paola, medium"],
				["pt_BR-faber-medium", "Portuguese (Brazil) — Faber, medium"]
			]
		},
		"audio_tts.form.piper": {
			"object": "piper",
			"properties": ["audio_tts.piper_voice"]
		},
		"audio_tts.form.coqui": {
			"object": "coqui-default",
			"properties": ["audio_tts.coqui_model"]
		},
		"audio_tts.form.kokoro": {
			"object": "kokoro-default",
			"properties": ["audio_tts.kokoro_model"]
		},
		"audio_tts.form.bark": {
			"object": "bark-default",
			"properties": ["audio_tts.bark_model"]
		},
		"audio_tts.form.openai": {
			"object": "openai-tts",
			"properties": ["audio_tts.openai_model", "audio_tts.openai_voice", "audio_tts.api_key"]
		},
		"audio_tts.form.elevenlabs": {
			"object": "elevenlabs-default",
			"properties": ["audio_tts.elevenlabs_model", "audio_tts.elevenlabs_voice", "audio_tts.api_key"]
		},
		"audio_tts.profile": {
			"title": "TTS profile",
			"type": "string",
			"default": "piper",
			"enum": [
				["piper", "Piper"],
				["coqui-default", "Coqui TTS"],
				["kokoro-default", "Kokoro"],
				["bark-default", "Bark"],
				["openai-tts", "OpenAI TTS"],
				["elevenlabs-default", "ElevenLabs"]
			],
			"conditional": [
				{
					"value": "piper",
					"properties": ["audio_tts.form.piper"]
				},
				{
					"value": "coqui-default",
					"properties": ["audio_tts.form.coqui"]
				},
				{
					"value": "kokoro-default",
					"properties": ["audio_tts.form.kokoro"]
				},
				{
					"value": "bark-default",
					"properties": ["audio_tts.form.bark"]
				},
				{
					"value": "openai-tts",
					"properties": ["audio_tts.form.openai"]
				},
				{
					"value": "elevenlabs-default",
					"properties": ["audio_tts.form.elevenlabs"]
				}
			]
		}
	},
	"shape": [
		{
			"section": "Pipe",
			"title": "Text To Speech",
			"properties": ["audio_tts.profile"]
		}
	],
	"test": {
		"requires": ["ROCKETRIDE_TTS_TEST_ENABLED"],
		"profiles": ["coqui-default", "kokoro-default", "bark-default"],
		"outputs": ["text"],
		"cases": [
			{
				"name": "Coqui/Kokoro/Bark return payload",
				"text": "Hello from RocketRide",
				"expect": {
					"text": {
						"notEmpty": true
					}
				}
			}
		]
	}
}
