		"audio_tts.api_key": {
			"type": "string",
			"title": "API key",
			"secure": true,
			"ui": {
				"ui:widget": "ApiKeyWidget"
			}
		},
		"audio_tts.piper_voice": {
			"type": "string",
			"title": "Voice model",
			"description": "Piper preset from rhasspy/piper-voices (downloaded via Hugging Face Hub on first use).",
			"default": "en_US-lessac-medium",
			"enum": [
				["en_US-lessac-medium", "English (US) — Lessac, medium"],
				["en_US-amy-medium", "English (US) — Amy, medium"],
				["de_DE-thorsten-medium", "German — Thorsten, medium"],
				["es_ES-davefx-medium", "Spanish (Spain) — Davefx, medium"],
				["fr_FR-siwis-medium", "French — Siwis, medium"],
				["it_IT-paola-medium", "Italian — Paola, medium"],
				["pt_BR-faber-medium", "Portuguese (Brazil) — Faber, medium"]
