{
	"title": "Text To Speech",
	"protocol": "audio_tts://",
	"classType": ["audio"],
	"capabilities": [],
	"register": "filter",
	"node": "python",
	"path": "nodes.audio_tts",
	"prefix": "audio_tts",
	"description": ["Converts incoming text into speech audio using local or cloud TTS engines.", "Output is driven by wiring: audio lane streams PCM chunks; text lane emits JSON with mime type and base64 (no server file path — suitable when the engine runs remotely).", "Encoding (WAV vs MP3) is chosen automatically from connected output lanes (not a form field).", "Routing: without a model server, the engine runs locally and chooses CPU/GPU on the engine host; each profile downloads its weights/voices there. With --modelserver, Bark uses HF transformers on the server; Kokoro uses the kokoro loader; Piper uses the Piper loader; OpenAI/ElevenLabs may be proxied.", "Every profile uses curated dropdowns — see ``requirements.txt`` + ``depends()`` on load: ``piper-tts``, ``transformers``, ``kokoro``, ``lameenc``, ``imageio-ffmpeg``, ``requests``, etc."],
	"icon": "audio-player.svg",
	"lanes": {
		"text": ["audio", "text"]
	},
	"input": [
		{
			"lane": "text",
			"description": "Text input for speech synthesis",
			"output": [
				{
					"lane": "audio"
				},
				{
					"lane": "text"
				}
			]
		}
	],
	"preconfig": {
		"default": "piper",
		"profiles": {
			"piper": {
				"engine": "piper",
				"piper_voice": "en_US-lessac-medium"
			},
			"kokoro": {
				"engine": "kokoro",
				"kokoro_lang_code": "a",
				"kokoro_voice": "af_heart"
			},
			"bark": {
				"engine": "bark",
				"bark_model": "suno/bark-small"
			},
			"openai": {
				"engine": "openai",
				"openai_model": "gpt-4o-mini-tts",
				"openai_voice": "alloy",
				"api_key": ""
			},
			"elevenlabs": {
				"engine": "elevenlabs",
				"elevenlabs_model": "eleven_multilingual_v2",
				"elevenlabs_voice": "EXAVITQu4vr4xnSDxMaL",
				"api_key": ""
			}
		}
	},
	"fields": {
		"audio_tts.kokoro_lang_code": {
			"type": "string",
			"title": "Language",
			"description": "Must match the Kokoro voice family (see hexgrad/Kokoro-82M VOICES.md).",
			"default": "a",
			"enum": [
				["a", "American English"],
				["b", "British English"],
				["e", "Spanish"],
				["f", "French"],
				["h", "Hindi"],
				["i", "Italian"],
				["j", "Japanese (may need misaki[ja])"],
				["p", "Brazilian Portuguese"],
				["z", "Mandarin Chinese (may need misaki[zh])"]
			]
		},
		"audio_tts.kokoro_voice": {
			"type": "string",
			"title": "Voice",
			"description": "Kokoro voice id; pair with Language (e.g. af_* / am_* with American English).",
			"default": "af_heart",
			"enum": [
				["af_heart", "American — af_heart"],
				["af_bella", "American — af_bella"],
				["af_nicole", "American — af_nicole"],
				["af_sarah", "American — af_sarah"],
				["af_sky", "American — af_sky"],
				["af_alloy", "American — af_alloy"],
				["af_aoede", "American — af_aoede"],
				["af_jessica", "American — af_jessica"],
