{
    "title": "Image - Mistral Vision",
    "protocol": "image_vision_mistral://",
    "classType": ["image"],
    "capabilities": ["invoke"],
    "register": "filter",
    "node": "python",
    "path": "nodes.llm_vision_mistral",
    "prefix": "image_vision_mistral",
    "description": [
        "A component that connects to Mistral AI's vision-capable models for image analysis, ",
        "OCR, and visual understanding tasks. Supports all Mistral vision models including ",
        "Pixtral and vision-enabled Mistral models. Features robust error handling, ",
        "automatic image processing, and flexible prompt configuration for various use cases."
    ],
    "documentation": "https://bit.ly/47iG5Ft",
    "icon": "mistral-vision.svg",
    "tile": [
        "Model: ${parameters.image_vision_mistral.profile}"
    ],
    "lanes": {
        "image": ["text"]
    },
    "input": [
        {
            "lane": "image",
            "description": "Image to analyze with Mistral Vision models",
            "output": [
                {
                    "lane": "text",
                    "description": "Text analysis of the image content"
                }
            ]
        }
    ],
    "preconfig": {
        "default": "pixtral-large",
        "profiles": {
            "pixtral-large": {
                "title": "Pixtral Large - Vision Frontier (128k tokens)",
                "model": "pixtral-large-2411",
                "modelTotalTokens": 128000,
                "apikey": ""
            },
            "mistral-large-3": {
                "title": "Mistral Large 3 - Premier Vision (256k tokens)",
                "model": "mistral-large-2512",
                "modelTotalTokens": 256000,
                "apikey": ""
            },
            "mistral-medium-3.1": {
                "title": "Mistral Medium 3.1 - Balanced Vision (128k tokens)",
                "model": "mistral-medium-2508",
                "modelTotalTokens": 128000,
                "apikey": ""
            },
            "mistral-small-3.2": {
                "title": "Mistral Small 3.2 - Fast & Cheap Vision (128k tokens)",
                "model": "mistral-small-2506",
                "modelTotalTokens": 128000,
                "apikey": ""
            },
            "ministral-14b-3": {
                "title": "Ministral 3 14B - High Performance Vision (256k tokens)",
                "model": "ministral-14b-2512",
                "modelTotalTokens": 256000,
                "apikey": ""
            },
            "ministral-8b-3": {
                "title": "Ministral 3 8B - Balanced Vision (256k tokens)",
                "model": "ministral-8b-2512",
                "modelTotalTokens": 256000,
                "apikey": ""
            },
            "ministral-3b-3": {
                "title": "Ministral 3 3B - Efficient Vision (256k tokens)",
                "model": "ministral-3b-2512",
                "modelTotalTokens": 256000,
                "apikey": ""
            }
        }
    },
    "fields": {
        "model": {
            "type": "string",
            "title": "Model",
            "description": "Mistral Vision model"
        },
        "modelTotalTokens": {
            "type": "number",
            "title": "Tokens",
            "description": "Maximum context length in tokens"
        },
        "vision.systemPrompt": {
            "type": "string",
            "title": "System Instructions",
            "description": "Define the model's role and behavior for image analysis",
            "examples": [
                "You are an OCR specialist. Extract all text from images accurately.",
                "You are a receipt analyzer. Extract bill numbers, items, prices, and totals.",
                "You are a document analyzer. Identify and describe all elements in the document.",
                "You are a chart interpreter. Analyze and explain data visualizations clearly."
            ]
        },
        "vision.prompt": {
            "type": "string",
            "title": "Analysis Prompt",
            "description": "Describe what you want to analyze or extract from the image",
            "examples": [
                "Transcribe this receipt",
                "Extract the text from this document",
                "Describe this chart in detail",
                "What are the key elements in this image?",
                "Extract items and prices from this receipt"
            ]
        },
        "image_vision_mistral.pixtral-large": {
            "object": "pixtral-large",
            "properties": [
                "llm.cloud.apikey",
                "vision.systemPrompt",
                "vision.prompt"
            ]
        },
        "image_vision_mistral.mistral-large-3": {
            "object": "mistral-large-3",
            "properties": [
                "llm.cloud.apikey",
                "vision.systemPrompt",
                "vision.prompt"
            ]
        },
        "image_vision_mistral.mistral-medium-3.1": {
            "object": "mistral-medium-3.1",
            "properties": [
                "llm.cloud.apikey",
                "vision.systemPrompt",
                "vision.prompt"
            ]
        },
        "image_vision_mistral.mistral-small-3.2": {
            "object": "mistral-small-3.2",
            "properties": [
                "llm.cloud.apikey",
                "vision.systemPrompt",
                "vision.prompt"
            ]
        },
        "image_vision_mistral.ministral-14b-3": {
            "object": "ministral-14b-3",
            "properties": [
                "llm.cloud.apikey",
                "vision.systemPrompt",
                "vision.prompt"
            ]
        },
        "image_vision_mistral.ministral-8b-3": {
            "object": "ministral-8b-3",
            "properties": [
                "llm.cloud.apikey",
                "vision.systemPrompt",
                "vision.prompt"
            ]
        },
        "image_vision_mistral.ministral-3b-3": {
            "object": "ministral-3b-3",
            "properties": [
                "llm.cloud.apikey",
                "vision.systemPrompt",
                "vision.prompt"
            ]
        },
        "image_vision_mistral.profile": {
            "title": "Vision Model",
            "description": "Select the Mistral vision model to use",
            "type": "string",
            "default": "pixtral-large",
            "enum": [
                "*>preconfig.profiles.*.title"
            ],
            "conditional": [
                {
                    "value": "pixtral-large",
                    "properties": [
                        "image_vision_mistral.pixtral-large"
                    ]
                },
                {
                    "value": "mistral-large-3",
                    "properties": [
                        "image_vision_mistral.mistral-large-3"
                    ]
                },
                {
                    "value": "mistral-medium-3.1",
                    "properties": [
                        "image_vision_mistral.mistral-medium-3.1"
                    ]
                },
                {
                    "value": "mistral-small-3.2",
                    "properties": [
                        "image_vision_mistral.mistral-small-3.2"
                    ]
                },
                {
                    "value": "ministral-14b-3",
                    "properties": [
                        "image_vision_mistral.ministral-14b-3"
                    ]
                },
                {
                    "value": "ministral-8b-3",
                    "properties": [
                        "image_vision_mistral.ministral-8b-3"
                    ]
                },
                {
                    "value": "ministral-3b-3",
                    "properties": [
                        "image_vision_mistral.ministral-3b-3"
                    ]
                }
            ]
        }
    },
    "shape": [
        {
            "section": "Pipe",
            "title": "Image - Mistral Vision",
            "properties": [
                "image_vision_mistral.profile"
            ]
        }
    ]
} 
