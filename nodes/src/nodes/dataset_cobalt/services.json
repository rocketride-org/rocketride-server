{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Cobalt Dataset",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "dataset_cobalt://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": [
		"source"
	],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": [],
	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "filter",
	//
	// Optional:
	//		The node is the actual pyhsical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",
	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	// 		and is optional for most node
	//
	"path": "nodes.dataset_cobalt",
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "dataset",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": [
		"Loads evaluation datasets using Cobalt AI's Dataset class. ",
		"Supports JSON, CSV, JSONL files with filtering, sampling, and transformation. ",
		"Feeds test data into pipelines for batch evaluation and quality testing."
	],
	//
	//  Optional:
	//      Rendering hints to the UI which indicate which fields of
	//      the configuration should be used to display information
	//
	"tile": [],
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"questions": [
			"questions"
		]
	},
	"input": [
		{
			"lane": "questions",
			"output": [
				{
					"lane": "questions"
				}
			]
		}
	],
	//
	//	Optional:
	//		Profile section are configuration options used by the driver
	//		itself
	//
	"preconfig": {
		"default": "file",
		"profiles": {
			"file": {
				"source_type": "file"
			},
			"inline": {
				"source_type": "inline"
			},
			"custom": {
				"source_type": "file"
			}
		}
	},
	//
	// Optional:
	//		Test configuration for automated node testing
	//
	"test": {
		"profiles": [
			"file",
			"inline"
		],
		"cases": [
			{
				"text": "Load dataset",
				"expect": {
					"questions": {
						"count": ">0"
					}
				}
			}
		]
	},
	//
	// Optional:
	//		Local fields defintions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"dataset.source_type": {
			"type": "string",
			"title": "Source Type",
			"description": "Where to load the dataset from: file (JSON/CSV/JSONL) or inline items.",
			"default": "file",
			"enum": [
				[
					"file",
					"File (JSON, CSV, JSONL)"
				],
				[
					"inline",
					"Inline Items"
				]
			],
			"conditional": [
				{
					"value": "file",
					"properties": [
						"dataset.file_path"
					]
				},
				{
					"value": "inline",
					"properties": [
						"dataset.items"
					]
				}
			]
		},
		"dataset.file_path": {
			"type": "string",
			"title": "File Path",
			"description": "Absolute path to the dataset file (JSON, CSV, or JSONL format)."
		},
		"dataset.items": {
			"type": "string",
			"title": "Inline Items (JSON)",
			"description": "JSON array of dataset items, e.g. [{\"input\": \"...\", \"expected\": \"...\"}].",
			"format": "textarea",
			"default": "[{\"input\": \"What is 2+2?\", \"expected\": \"4\"}]"
		},
		"dataset.sample_size": {
			"type": "number",
			"title": "Sample Size",
			"description": "Number of random items to sample from the dataset. 0 means use all items.",
			"default": 0
		},
		"dataset.filter_field": {
			"type": "string",
			"title": "Filter Field",
			"description": "Optional field name to filter dataset items on."
		},
		"dataset.filter_value": {
			"type": "string",
			"title": "Filter Value",
			"description": "Value that the filter field must match."
		},
		"dataset.slice_start": {
			"type": "number",
			"title": "Slice Start",
			"description": "Start index for slicing the dataset (0-based).",
			"default": 0
		},
		"dataset.slice_end": {
			"type": "number",
			"title": "Slice End",
			"description": "End index for slicing the dataset. 0 means no slicing.",
			"default": 0
		},
		"dataset.default": {
			"object": "default",
			"properties": [
				"dataset.source_type",
				"dataset.sample_size",
				"dataset.filter_field",
				"dataset.filter_value",
				"dataset.slice_start",
				"dataset.slice_end"
			]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "Cobalt Dataset",
			"properties": [
				"dataset.default"
			]
		}
	]
}
