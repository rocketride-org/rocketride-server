    "prefix": "llm",
    "description": [
        "A component that connects to Mistral AI's advanced language models for natural language processing. ",
        "Supports a wide range of models from large (128K context) to small (32K context), including specialized ",
        "models for reasoning and technical tasks. Features high-quality chat completions with robust error handling ",
        "and automatic token management."
    ],
    "documentation": "https://bit.ly/3X7t1wC",
    "icon": "mistral.svg",
