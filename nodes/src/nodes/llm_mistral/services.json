{
	"title": "Mistral AI",
	"protocol": "llm_mistral://",
	"classType": ["llm"],
	"capabilities": ["invoke"],
	"register": "filter",
	"node": "python",
	"path": "nodes.llm_mistral",
	"prefix": "llm",
	"description": ["A component that connects to Mistral AI's advanced language models for natural language processing. ", "Supports a wide range of models from large (256K context) to small (32K context), including specialized ", "models for reasoning and technical tasks. Features high-quality chat completions with robust error handling ", "and automatic token management."],
	"icon": "mistral.svg",
	"documentation": "https://docs.rocketride.org",
	"tile": ["Model: ${parameters.llm_mistral.profile}"],
	"lanes": {
		"questions": ["answers"]
	},
	"input": [
		{
			"lane": "questions",
			"output": [
				{
					"lane": "answers"
				}
			]
		}
	],
	"preconfig": {
		"default": "mistral-large",
		"profiles": {
			"custom": {
				"title": "Custom Model",
				"model": "",
				"modelTotalTokens": 32768,
				"apikey": ""
			},
			"mistral-large": {
				"title": "Mistral Large 3",
				"model": "mistral-large-2512",
				"modelTotalTokens": 256000,
				"apikey": ""
			},
			"mistral-medium": {
				"title": "Mistral Medium 3.1",
				"model": "mistral-medium-2508",
				"modelTotalTokens": 131072,
				"apikey": ""
			},
			"mistral-small": {
				"title": "Mistral Small 3.2",
				"model": "mistral-small-2506",
				"modelTotalTokens": 131072,
				"apikey": ""
			},
			"codestral": {
				"title": "Codestral",
				"model": "codestral-2508",
				"modelTotalTokens": 262144,
				"apikey": ""
			},
			"magistral-medium": {
				"title": "Magistral Medium 1.2",
				"model": "magistral-medium-2509",
				"modelTotalTokens": 40960,
				"apikey": ""
			},
			"magistral-small": {
				"title": "Magistral Small 1.2",
				"model": "magistral-small-2509",
				"modelTotalTokens": 40960,
				"apikey": ""
			},
			"devstral-medium": {
				"title": "Devstral Medium 1.0",
				"model": "devstral-medium-2507",
				"modelTotalTokens": 131072,
				"apikey": ""
			},
			"devstral-small": {
				"title": "Devstral Small 1.1",
				"model": "devstral-small-2507",
				"modelTotalTokens": 131072,
				"apikey": ""
			},
			"ministral-14b": {
				"title": "Ministral 3 14B",
				"model": "ministral-14b-2512",
				"modelTotalTokens": 256000,
				"apikey": ""
			},
			"ministral-8b": {
				"title": "Ministral 3 8B",
				"model": "ministral-8b-2512",
				"modelTotalTokens": 256000,
				"apikey": ""
			},
			"ministral-3b": {
				"title": "Ministral 3 3B",
				"model": "ministral-3b-2512",
				"modelTotalTokens": 256000,
				"apikey": ""
			}
		}
	},
	"fields": {
		"model": {
			"type": "string",
			"title": "Model",
			"description": "Mistral AI model"
		},
		"modelTotalTokens": {
			"type": "number",
			"title": "Tokens",
			"description": "Maximum context length in tokens"
		},
		"mistral.custom": {
			"object": "custom",
			"properties": ["model", "modelTotalTokens", "llm.cloud.apikey"]
		},
		"mistral.mistral-large": {
			"object": "mistral-large",
			"properties": ["llm.cloud.apikey"]
		},
		"mistral.mistral-medium": {
			"object": "mistral-medium",
			"properties": ["llm.cloud.apikey"]
		},
		"mistral.mistral-small": {
			"object": "mistral-small",
			"properties": ["llm.cloud.apikey"]
		},
		"mistral.codestral": {
			"object": "codestral",
			"properties": ["llm.cloud.apikey"]
		},
		"mistral.magistral-medium": {
			"object": "magistral-medium",
			"properties": ["llm.cloud.apikey"]
		},
		"mistral.magistral-small": {
			"object": "magistral-small",
			"properties": ["llm.cloud.apikey"]
		},
		"mistral.devstral-medium": {
			"object": "devstral-medium",
			"properties": ["llm.cloud.apikey"]
		},
		"mistral.devstral-small": {
			"object": "devstral-small",
			"properties": ["llm.cloud.apikey"]
		},
		"mistral.ministral-14b": {
			"object": "ministral-14b",
			"properties": ["llm.cloud.apikey"]
		},
		"mistral.ministral-8b": {
			"object": "ministral-8b",
			"properties": ["llm.cloud.apikey"]
		},
		"mistral.ministral-3b": {
			"object": "ministral-3b",
			"properties": ["llm.cloud.apikey"]
		},
		"mistral.profile": {
			"title": "Model",
			"description": "Mistral AI model selection",
			"type": "string",
			"default": "mistral-large",
			"enum": ["*>preconfig.profiles.*.title"],
			"conditional": [
				{
					"value": "custom",
					"properties": ["mistral.custom"]
				},
				{
					"value": "mistral-large",
					"properties": ["mistral.mistral-large"]
				},
				{
					"value": "mistral-medium",
					"properties": ["mistral.mistral-medium"]
				},
				{
					"value": "mistral-small",
					"properties": ["mistral.mistral-small"]
				},
				{
					"value": "codestral",
					"properties": ["mistral.codestral"]
				},
				{
					"value": "magistral-medium",
					"properties": ["mistral.magistral-medium"]
				},
				{
					"value": "magistral-small",
					"properties": ["mistral.magistral-small"]
				},
				{
					"value": "devstral-medium",
					"properties": ["mistral.devstral-medium"]
				},
				{
					"value": "devstral-small",
					"properties": ["mistral.devstral-small"]
				},
				{
					"value": "ministral-14b",
					"properties": ["mistral.ministral-14b"]
				},
				{
					"value": "ministral-8b",
					"properties": ["mistral.ministral-8b"]
				},
				{
					"value": "ministral-3b",
					"properties": ["mistral.ministral-3b"]
				}
			]
		}
	},
	"shape": [
		{
			"section": "Pipe",
			"title": "Mistral AI",
			"properties": ["mistral.profile"]
		}
	]
}
