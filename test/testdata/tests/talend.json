              "bodyType": "Text",
              "textBodyEditorHeight": 362,
              "textBody": "{\n    \"pipeline\": {\n        \"source\": \"source_1\",\n        \"components\": [\n            {\n                \"id\": \"source_1\",\n                \"provider\": \"filesys\",\n                \"config\": {\n                    \"actions\": {},\n                    \"estimation\": {\n                        \"accessCost\": 0,\n                        \"accessDelay\": 0,\n                        \"accessRate\": 0,\n                        \"storeCost\": 0\n                    },\n                    \"include\": [\n                        {\n                            \"classify\": true,\n                            \"index\": true,\n                            \"ocr\": true,\n                            \"path\": \"C:\\\\test\",\n                            \"permissions\": true,\n                            \"signing\": true,\n                            \"vectorize\": false\n                        }\n                    ],\n                    \"key\": \"filesys://*\",\n                    \"mode\": \"Source\",\n                    \"name\": \"File System\",\n                    \"parameters\": {\n                        \"auth\": \"secure\",\n                        \"format\": \"native\",\n                        \"secureParameters\": {\n                            \"readonly\": [],\n                            \"secure\": [],\n                            \"token\": \"ToIyPoSGQk2sB2Mw+p3jh3R0L2Xdwltcgj4bZln2dHV7/huJ\"\n                        }\n                    },\n                    \"sync\": false,\n                    \"type\": \"filesys\"\n                },\n                \"ui\": {}\n            },\n            {\n                \"id\": \"parser_1\",\n                \"provider\": \"parse\",\n                \"config\": {},\n                \"ui\": {},\n                \"input\": [\n                    {\n                        \"lane\": \"tag\",\n                        \"from\": \"source_1\"\n                    }\n                ]\n            },\n            {\n                \"id\": \"preprocessor_1\",\n                \"provider\": \"preprocessor_langchain\",\n                \"ui\": {},\n                \"config\": {\n                    \"profile\": \"string\",\n                    \"chunk_size\": 1024\n                },\n                \"input\": [\n                    {\n                        \"lane\": \"text\",\n                        \"from\": \"parser_1\"\n                    }\n                ]\n            },\n            {\n                \"id\": \"embedding_1\",\n                \"provider\": \"embedding_transformer\",\n                \"ui\": {},\n                \"config\": {},\n                \"input\": [\n                    {\n                        \"lane\": \"documents\",\n                        \"from\": \"preprocessor_1\"\n                    }\n                ]\n            },\n            {\n                \"id\": \"qdrant_1\",\n                \"provider\": \"qdrant\",\n                \"ui\": {},\n                \"profile\": \"local\",\n                \"config\": {\n                    \"collection\": \"denodo_collection\"\n                },\n                \"input\": [\n                    {\n                        \"lane\": \"documents\",\n                        \"from\": \"embedding_1\"\n                    }\n                ]\n            },\n            {\n                \"id\": \"definitions_1\",\n                \"provider\": \"definitions\",\n                \"ui\": {},\n                \"config\": {},\n                \"input\": [\n                    {\n                        \"lane\": \"text\",\n                        \"from\": \"parser_1\"\n                    },\n                    {\n                        \"lane\": \"answers\",\n                        \"from\": \"chat_1\"\n                    }\n                ]\n            },\n            {\n                \"id\": \"chat_1\",\n                \"provider\": \"chat_openai\",\n                \"ui\": {},\n                \"config\": {\n                    \"apikey\": \"insert your key here\"\n                },\n                \"input\": [\n                    {\n                        \"lane\": \"questions\",\n                        \"from\": \"definitions_1\"\n                    }\n                ]\n            },\n            {\n                \"id\": \"embedding_2\",\n                \"provider\": \"embedding_transformer\",\n                \"ui\": {},\n                \"input\": [\n                    {\n                        \"lane\": \"documents\",\n                        \"from\": \"definitions_1\"\n                    }\n                ]\n            },\n            {\n                \"id\": \"response_1\",\n                \"provider\": \"response\",\n                \"ui\": {},\n                \"config\": {\n                    \"keys\": {\n                        \"documents\": \"procdocs\"\n                    }\n                },\n                \"input\": [\n                    {\n                        \"lane\": \"documents\",\n                        \"from\": \"embedding_1\"\n                    }\n                ]\n            },\n            {\n                \"id\": \"response_2\",\n                \"provider\": \"response\",\n                \"ui\": {},\n                \"config\": {\n                    \"keys\": {\n                        \"documents\": \"defdocs\",\n                        \"answers\": \"defanswers\"\n                    }\n                },\n                \"input\": [\n                    {\n                        \"lane\": \"documents\",\n                        \"from\": \"embedding_2\"\n                    },\n                    {\n                        \"lane\": \"answers\",\n                        \"from\": \"chat_1\"\n                    },\n                    {\n                        \"lane\": \"questions\",\n                        \"from\": \"definitions_1\"\n                    }\n                ]\n            },\n            {\n                \"id\": \"qdrant_2\",\n                \"provider\": \"qdrant\",\n                \"ui\": {},\n                \"profile\": \"local\",\n                \"config\": {\n                    \"collection\": \"denodo_dictionary\"\n                },\n                \"input\": [\n                    {\n                        \"lane\": \"documents\",\n                        \"from\": \"embedding_2\"\n                    }\n                ]\n            }\n        ]\n    }\n}"
