              "textBody": "{\n\t\"pipeline\": {\n\t\t\"source\": \"source_1\",\n\t\t\"components\": [\n\t\t\t{\n\t\t\t\t\"id\": \"source_1\",\n\t\t\t\t\"provider\": \"webhook\",\n\t\t\t\t\"config\": {\n\t\t\t\t\t\"key\": \"webhook://*\",\n\t\t\t\t\t\"mode\": \"Source\",\n\t\t\t\t\t\"name\": \"Web Hook\",\n\t\t\t\t\t\"include\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"path\": \"*\"\n\t\t\t\t\t\t}\n\t\t\t\t\t],\n\t\t\t\t\t\"parameters\": {\n\t\t\t\t\t\t\"endpoint\": \"/processDocs\",\n\t\t\t\t\t\t\"port\": 8799\n\t\t\t\t\t},\n\t\t\t\t\t\"sync\": false,\n\t\t\t\t\t\"type\": \"webhook\"\n\t\t\t\t},\n\t\t\t\t\"ui\": {}\n\t\t\t},\n\t\t\t{\n\t\t\t\t\"id\": \"parser_1\",\n\t\t\t\t\"provider\": \"parse\",\n\t\t\t\t\"config\": {},\n\t\t\t\t\"ui\": {},\n\t\t\t\t\"input\": [\n\t\t\t\t\t{\n\t\t\t\t\t\t\"lane\": \"tag\",\n\t\t\t\t\t\t\"from\": \"source_1\"\n\t\t\t\t\t}\n\t\t\t\t]\n\t\t\t},\n\t\t\t{\n\t\t\t\t\"id\": \"response_1\",\n\t\t\t\t\"provider\": \"response\",\n\t\t\t\t\"ui\": {},\n\t\t\t\t\"config\": {},\n\t\t\t\t\"input\": [\n\t\t\t\t\t{\n\t\t\t\t\t\t\"lane\": \"audio\",\n\t\t\t\t\t\t\"from\": \"parser_1\"\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\t\"lane\": \"audio\",\n\t\t\t\t\t\t\"from\": \"source_1\"\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\t\"lane\": \"video\",\n\t\t\t\t\t\t\"from\": \"parser_1\"\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\t\"lane\": \"video\",\n\t\t\t\t\t\t\"from\": \"source_1\"\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\t\"lane\": \"image\",\n\t\t\t\t\t\t\"from\": \"parser_1\"\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\t\"lane\": \"image\",\n\t\t\t\t\t\t\"from\": \"source_1\"\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\t\"lane\": \"text\",\n\t\t\t\t\t\t\"from\": \"parser_1\"\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\t\"lane\": \"text\",\n\t\t\t\t\t\t\"from\": \"source_1\"\n\t\t\t\t\t}\n\t\t\t\t]\n\t\t\t}\n\t\t]\n\t}\n}"
