{
	"name": "rocketride",
	"displayName": "RocketRide",
	"description": "RocketRide extension for Visual Studio Code",
	"version": "0.0.1",
	"publisher": "rocketride",
	"repository": {
		"type": "git",
		"url": "https://github.com/rocketride-ai/rocketride-server.git"
	},
	"homepage": "https://github.com/rocketride-ai/rocketride-server#readme",
	"bugs": {
		"url": "https://github.com/rocketride-ai/rocketride-server/issues"
	},
	"license": "MIT",
	"keywords": [
		"rocketride",
		"data",
		"pipeline",
		"debugger",
		"toolchain"
	],
	"icon": "rocketride-dark-icon.png",
	"engines": {
		"vscode": "^1.99.3"
	},
	"categories": [
		"Debuggers",
		"Other"
	],
	"activationEvents": [
		"onStartupFinished",
		"onDebugResolve:rocketride",
		"onDebug:rocketride",
		"onLanguage:pipeline",
		"onDebugInitialConfigurations",
		"onDebugDynamicConfigurations"
	],
	"contributes": {
		"breakpoints": [
			{
				"language": "pipeline"
			}
		],
		"customEditors": [
			{
				"viewType": "rocketride.PageEditor",
				"displayName": "Pipeline Grid Editor",
				"selector": [
					{
						"filenamePattern": "*.pipe"
					},
					{
						"filenamePattern": "*.pipe.json"
					}
				],
				"priority": "default"
			}
		],
		"configurationDefaults": {
			"files.associations": {
				"*.pipe": "json"
			}
		},
		"configuration": {
			"title": "RocketRide",
			"properties": {
				"rocketride.connectionMode": {
					"type": "string",
					"enum": [
						"cloud",
						"onprem",
						"local"
					],
					"default": "local",
					"description": "Connection mode for RocketRide debugging",
					"enumDescriptions": [
						"Cloud (RocketRide.ai cloud) – needs a RocketRide account",
						"On-prem (your own hosted server) – needs host address and API key",
						"Local (your local machine) – just needs a port to connect to"
					]
				},
				"rocketride.hostUrl": {
					"type": "string",
					"default": "http://localhost:5565",
					"description": "Host URL for RocketRide service (used by both cloud and local modes). Host and port will be parsed from this URL.",
					"format": "uri"
				},
				"rocketride.deployUrl": {
					"type": "string",
					"default": "https://cloud.rocketride.ai",
					"description": "Base URL for the deploy API when using Deploy to RocketRide.ai. Can differ from the development server URL.",
					"format": "uri"
				},
				"rocketride.defaultPipelinePath": {
					"type": "string",
					"default": "${workspaceFolder}/pipelines",
					"description": "Default directory path for creating new pipeline files (relative to workspace root)",
					"examples": [
						"pipelines",
						"src/pipelines",
						"workflows"
					]
				},
				"rocketride.local.engineVersion": {
					"type": "string",
					"default": "latest",
					"description": "Engine version to download. 'latest' for newest stable, 'prerelease' for newest prerelease, or a specific tag like 'server-v3.1.1'."
				},
				"rocketride.local.engineArgs": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Additional arguments for local engine startup"
				},
				"rocketride.autoConnect": {
					"type": "boolean",
					"default": true,
					"description": "Automatically connect to RocketRide server when extension activates"
				},
				"rocketride.pipelineRestartBehavior": {
					"type": "string",
					"enum": [
						"auto",
						"manual",
						"prompt"
					],
					"default": "prompt",
					"description": "Behavior when a .pipe file changes while the pipeline is running",
					"enumDescriptions": [
						"Automatically restart the pipeline",
						"Do not automatically restart the pipeline",
						"Prompt the user to restart the pipeline"
					]
				},
				"rocketride.copilotIntegration": {
					"type": "boolean",
					"default": false,
					"description": "Enable GitHub Copilot integration"
				},
				"rocketride.cursorIntegration": {
					"type": "boolean",
					"default": false,
					"description": "Enable Cursor integration"
				},
				"rocketride.oauth2RootUrl": {
					"type": "string",
					"default": "https://oauth2.rocketride.ai",
					"description": "Root OAuth2 URL for the refresh path (lambda) passed to the services OAuth2 endpoint. No UI to change it.",
					"format": "uri"
				}
			}
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "rocketride",
					"title": "RocketRide",
					"icon": "./rocketride-light-icon.png"
				}
			]
		},
		"commands": [
			{
				"command": "rocketride.sidebar.connection.connect",
				"title": "Connect to Server",
				"category": "RocketRide",
				"icon": "$(debug-start)"
			},
			{
				"command": "rocketride.sidebar.connection.disconnect",
				"title": "Disconnect from Server",
				"category": "RocketRide",
				"icon": "$(debug-stop)"
			},
			{
				"command": "rocketride.sidebar.connection.reconnect",
				"title": "Reconnect to Server",
				"category": "RocketRide",
				"icon": "$(debug-restart)"
			},
			{
				"command": "rocketride.page.settings.open",
				"title": "Open RocketRide Settings",
				"category": "RocketRide",
				"icon": "$(settings-gear)"
			},
			{
				"command": "rocketride.openPipelineAsText",
				"title": "Open as Text",
				"category": "RocketRide",
				"icon": "$(file-text)"
			},
			{
				"command": "rocketride.page.settings.setupCredentials",
				"title": "Setup API Key & URL",
				"category": "RocketRide",
				"icon": "$(key)"
			},
			{
				"command": "rocketride.page.settings.updateApiKey",
				"title": "Update API Key",
				"category": "RocketRide",
				"icon": "$(edit)"
			},
			{
				"command": "rocketride.page.settings.clearApiKey",
				"title": "Clear API Key",
				"category": "RocketRide",
				"icon": "$(trash)"
			},
			{
				"command": "rocketride.refresh",
				"title": "Refresh All",
				"icon": "$(refresh)",
				"category": "RocketRide"
			},
			{
				"command": "rocketride.sidebar.files.refresh",
				"title": "Refresh",
				"icon": "$(refresh)",
				"category": "RocketRide Pipeline"
			},
			{
				"command": "rocketride.sidebar.files.openFile",
				"title": "Open Status Page",
				"icon": "$(dashboard)",
				"category": "RocketRide Pipeline"
			},
			{
				"command": "rocketride.sidebar.files.openStatus",
				"title": "Select Component",
				"icon": "$(symbol-class)",
				"category": "RocketRide Pipeline"
			},
			{
				"command": "rocketride.sidebar.files.createFile",
				"title": "Create New Pipeline",
				"icon": "$(add)",
				"category": "RocketRide Pipeline"
			},
			{
				"command": "rocketride.page.status.open",
				"title": "Open Status Page",
				"category": "RocketRide",
				"icon": "$(dashboard)"
			},
			{
				"command": "rocketride.sidebar.files.runPipeline",
				"title": "Run",
				"icon": "$(play)",
				"category": "RocketRide Pipeline"
			},
			{
				"command": "rocketride.sidebar.files.launchPipeline",
				"title": "Debug Pipeline",
				"icon": "$(debug-alt)",
				"category": "RocketRide Pipeline"
			},
			{
				"command": "rocketride.sidebar.files.attachPipeline",
				"title": "Attach to Pipeline",
				"icon": "$(debug-disconnect)",
				"category": "RocketRide Pipeline"
			},
			{
				"command": "rocketride.page.deploy.open",
				"title": "Open Deploy",
				"category": "RocketRide",
				"icon": { "dark": "./rocketride-light-icon.png", "light": "./rocketride-dark-icon.png" }
			},
			{
				"command": "rocketride.page.welcome.open",
				"title": "Welcome",
				"category": "RocketRide"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "rocketride.sidebar.files.refresh",
					"when": "view == rocketride.provider.files",
					"group": "navigation"
				},
				{
					"command": "rocketride.sidebar.files.createFile",
					"when": "view == rocketride.provider.files",
					"group": "navigation@2"
				}
			],
			"view/item/context": [
				{
					"command": "rocketride.sidebar.files.runPipeline",
					"when": "view == rocketride.provider.files && viewItem =~ /^pipelineSource:stopped/",
					"group": "inline@1"
				},
				{
					"command": "rocketride.sidebar.files.launchPipeline",
					"when": "view == rocketride.provider.files && viewItem =~ /^pipelineSource:stopped/",
					"group": "inline@2"
				},
				{
					"command": "rocketride.page.deploy.open",
					"when": "view == rocketride.provider.files && viewItem =~ /^pipelineSource/",
					"group": "inline@3"
				},
				{
					"command": "rocketride.sidebar.files.attachPipeline",
					"when": "view == rocketride.provider.files && viewItem =~ /^pipelineSource:running/ || view == rocketride.provider.files && viewItem == unknownTask",
					"group": "inline@1"
				}
			]
		},
		"debuggers": [
			{
				"type": "rocketride",
				"label": "RocketRide Debugger",
				"languages": [
					"pipeline"
				],
				"initialConfigurations": [
					{
						"type": "rocketride",
						"request": "launch",
						"name": "Launch RocketRide Pipeline",
						"file": "${file}",
						"source": ""
					}
				],
				"configurationSnippets": [
					{
						"label": "RocketRide: Launch",
						"description": "Launch a RocketRide pipeline file",
						"body": {
							"type": "rocketride",
							"request": "launch",
							"name": "Launch RocketRide",
							"file": "${1:${file\\}}"
						}
					},
					{
						"label": "RocketRide: Attach",
						"description": "Attach to a running RocketRide pipeline instance",
						"body": {
							"type": "rocketride",
							"request": "attach",
							"name": "Attach to RocketRide",
							"token": "${1:session-token}"
						}
					}
				],
				"configurationAttributes": {
					"launch": {
						"required": [],
						"properties": {
							"token": {
								"type": "string",
								"description": "Token to use for this pipeline"
							},
							"file": {
								"type": "string",
								"description": "Path to the pipeline file",
								"default": "${file}"
							},
							"source": {
								"type": "string",
								"description": "Source component within pipeline to start",
								"default": ""
							},
							"args": {
								"type": "array",
								"items": {
									"type": "string"
								},
								"description": "Command-line arguments"
							},
							"justMyCode": {
								"type": "boolean",
								"description": "Debug only user-written code, skipping system code",
								"default": true
							},
							"threads": {
								"type": "number",
								"description": "Number of threads to use (1-64)",
								"default": 1,
								"minimum": 1,
								"maximum": 64
							}
						}
					},
					"attach": {
						"required": [
							"token"
						],
						"properties": {
							"token": {
								"type": "string",
								"description": "Token for attaching to existing pipeline"
							},
							"source": {
								"type": "string",
								"description": "Source component within pipeline to start",
								"default": ""
							},
							"justMyCode": {
								"type": "boolean",
								"description": "Debug only user-written code, skipping system code",
								"default": true
							}
						}
					}
				}
			}
		],
		"views": {
			"rocketride": [
				{
					"type": "webview",
					"id": "rocketride.provider.connection",
					"name": "Connection Manager"
				},
				{
					"type": "tree",
					"id": "rocketride.provider.files",
					"name": "Pipelines",
					"when": "rocketride.loaded"
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "rocketride.provider.connection",
				"contents": "Loading..."
			},
			{
				"view": "rocketride.provider.files",
				"contents": "No pipeline files found"
			}
		]
	},
	"main": "./dist/rocketride.js",
	"devDependencies": {
		"@rsbuild/core": "^1.4.10",
		"@rsbuild/plugin-react": "^1.3.4",
		"@rsbuild/plugin-type-check": "^1.2.3",
		"@types/adm-zip": "^0.5.5",
		"@types/chart.js": "^2.9.41",
		"@types/mocha": "^10.0.10",
		"@types/node": "20.x",
		"@types/react": "^18.0.0",
		"@types/react-dom": "^19.2.3",
		"@types/vscode": "^1.99.0",
		"@types/vscode-webview": "^1.57.5",
		"@vscode/debugprotocol": "^1.68.0",
		"@vscode/test-cli": "^0.0.10",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.6.0",
		"esbuild": "^0.25.9",
		"react": "^18.3.1",
		"react-dom": "^19.2.4",
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"@octokit/rest": "^22.0.1",
		"rocketride": "workspace:*",
		"adm-zip": "^0.5.16",
		"chart.js": "^4.4.0",
		"shared": "workspace:*",
		"tar": "^7.5.8"
	},
	"files": [
		"rocketride-dark-icon.png",
		"rocketride-light-icon.png",
		"rocketride.js",
		"package.json",
		"LICENSE",
		"docs/**",
		"dist/**"
	]
}
