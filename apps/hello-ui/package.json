  "dependencies": {
    "@module-federation/rsbuild-plugin": "^0.9.0",
    "shell-ui": "workspace:*",
    "shared": "workspace:*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@rsbuild/core": "1.1.0",
    "@rsbuild/plugin-react": "1.0.7",
    "typescript": "^5.3.0"
  }
}
