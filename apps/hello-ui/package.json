{
  "name": "@rocketride/hello-ui",
  "version": "1.1.0",
  "private": true,
  "description": "RocketRide Hello — OSS landing page and dashboard",
  "license": "MIT",
  "appManifest": {
    "id": "rocketride.hello",
    "publisher": "Aparavi Software AG",
    "name": "RocketRide",
    "description": "Landing page and dashboard",
    "icon": "./src/icon.svg",
    "categories": ["built-in"],
    "mode": "free",
    "authenticated": false,
    "showStatusBar": true
  },
  "scripts": {
    "build": "pnpm rsbuild build",
    "build:prod": "pnpm rsbuild build --env-mode production"
