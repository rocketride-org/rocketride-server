{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build all",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/build.js",
				"vscode:clean",
				"vscode:build"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": []
		}
	]
}